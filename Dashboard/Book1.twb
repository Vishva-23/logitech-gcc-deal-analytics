    <worksheet name='New Vs returning '>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1' fontcolor='#000000' fontname='Tableau Book'>Customer Revenue: New vs Returning</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Logitech_Full_Enriched_Data' name='federated.16jc75z15nn7xc1esd3f21qtfw1j' />
          </datasources>
          <datasource-dependencies datasource='federated.16jc75z15nn7xc1esd3f21qtfw1j'>
            <column caption='First Purchase Year' datatype='integer' name='[Calculation_1550376087461888]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [Company Name] : MIN(YEAR([Close Date]))}' />
            </column>
            <column caption='Customer Cohort' datatype='string' name='[Calculation_1550376087613441]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF YEAR([Close Date]) = [Calculation_1550376087461888]&#13;&#10;THEN &quot;New Customer&quot;&#13;&#10;ELSE &quot;Returning Customer&quot;&#13;&#10;END' />
            </column>
            <column aggregation='Sum' datatype='integer' name='[Close Calender Year]' role='dimension' type='ordinal' user:agg-type='Year' user:base-field='Close Date' user:ui-builder='date-bin-builder'>
              <calculation class='tableau' formula='DATEPART(&apos;year&apos;, [Close Date])' />
            </column>
            <column datatype='date' name='[Close Date]' role='dimension' type='ordinal' />
            <column datatype='string' name='[Company Name]' role='dimension' type='nominal' />
            <column datatype='string' name='[Stage(SFDC)]' role='dimension' type='nominal' />
            <column datatype='real' name='[Total Price (converted USD)]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_1550376087613441]' derivation='None' name='[none:Calculation_1550376087613441:nk]' pivot='key' type='nominal' />
            <column-instance column='[Close Calender Year]' derivation='None' name='[none:Close Calender Year:ok]' pivot='key' type='ordinal' />
            <column-instance column='[Stage(SFDC)]' derivation='None' name='[none:Stage(SFDC):nk]' pivot='key' type='nominal' />
            <column-instance column='[Total Price (converted USD)]' derivation='Sum' name='[sum:Total Price (converted USD):qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.16jc75z15nn7xc1esd3f21qtfw1j].[none:Stage(SFDC):nk]'>
