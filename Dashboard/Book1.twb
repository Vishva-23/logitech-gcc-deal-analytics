        <calculation class='tableau' formula='RANK(SUM([Total Price (converted USD)]), &apos;desc&apos;)'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Region Label' datatype='string' name='[Calculation_0843114607169536]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [B2B Sales Region]&#13;&#10;  WHEN &quot;NAM&quot; THEN &quot;North America&quot;&#13;&#10;  WHEN &quot;EAD&quot; THEN &quot;Europe &amp; Africa&quot;&#13;&#10;  WHEN &quot;GEM&quot; THEN &quot;Emerging Markets&quot;&#13;&#10;  WHEN &quot;GCN&quot; THEN &quot;Greater China&quot;&#13;&#10;  ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
      <column caption='Representative Country' datatype='string' name='[Calculation_0843114607448065]' role='dimension' semantic-role='[Country].[Name]' type='nominal'>
        <calculation class='tableau' formula='CASE [B2B Sales Region]&#13;&#10;  WHEN &quot;NAM&quot; THEN &quot;United States&quot;&#13;&#10;  WHEN &quot;EAD&quot; THEN &quot;United Kingdom&quot;&#13;&#10;  WHEN &quot;GEM&quot; THEN &quot;Brazil&quot;&#13;&#10;  WHEN &quot;GCN&quot; THEN &quot;China&quot;&#13;&#10;  ELSE &quot;Other&quot;&#13;&#10;END' />
      </column>
      <column caption='BOX' datatype='string' name='[Calculation_1110570731835392]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;&quot;' />
      </column>
      <column caption='First Purchase Year' datatype='integer' name='[Calculation_1550376087461888]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [Company Name] : MIN(YEAR([Close Date]))}' />
      </column>
      <column caption='Customer Cohort' datatype='string' name='[Calculation_1550376087613441]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF YEAR([Close Date]) = [Calculation_1550376087461888]&#13;&#10;THEN &quot;New Customer&quot;&#13;&#10;ELSE &quot;Returning Customer&quot;&#13;&#10;END' />
      </column>
      <column caption='GSC Revenue Share' datatype='real' name='[Calculation_1550376104427522]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Account Type] = &quot;Global Strategic Customer&quot;&#13;&#10;THEN [Total Price (converted USD)]&#13;&#10;END' />
      </column>
      <column aggregation='Sum' datatype='integer' name='[Close Calender Year]' role='dimension' type='ordinal' user:agg-type='Year' user:base-field='Close Date' user:ui-builder='date-bin-builder'>
